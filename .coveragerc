[run]
source = bugbounty_mcp_server
omit =
    */tests/*
    */venv/*
    */env/*
    */__pycache__/*
    */.eggs/*
    *.egg-info/*

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    if self.debug:
    if __name__ == .__main__.:
    raise AssertionError
    raise NotImplementedError
    if 0:
    pass
    def __str__

ignore_errors = True

[html]
directory = coverage_html

[xml]
output = coverage.xml
